DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=

SERVER_PORT=3000

# CORS (comma-separated origins, e.g. http://localhost:4200,https://app.example.com)
CORS_ORIGIN=http://localhost:4200

# JWT configuration (secrets must be at least 32 characters)
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace-with-a-different-strong-random-secret-32-chars
JWT_REFRESH_EXPIRES_IN=7d

# Separate database for integration tests (must be created manually)
TEST_DB_NAME=app_test
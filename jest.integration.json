{
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.integration-spec\\.ts$",
    "extensionsToTreatAsEsm": [".ts"],
    "transform": {
        "^.+\\.ts$": [
            "ts-jest",
            {
                "useESM": true,
                "tsconfig": "tsconfig.integration.json"
            }
        ]
    },
    "moduleNameMapper": {
        "^src/(.*)\\.js$": "<rootDir>/$1",
        "^src/(.*)$": "<rootDir>/$1",
        "^(\\.{1,2}/.*)\\.(t|j)s$": "$1"
    },
    "testEnvironment": "node",
    "testTimeout": 30000
}

{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },
        "dev": {
            "dependsOn": ["^build"],
            "persistent": true,
            "cache": false
        },
        "test": {
            "dependsOn": ["^build"]
        },
        "test:integration": {
            "dependsOn": ["^build"],
            "cache": false
        },
        "lint": {
            "dependsOn": ["^build", "^generate", "generate"]
        },
        "check-types": {
            "dependsOn": ["^build", "^generate", "generate"]
        },
        "generate": {
            "cache": false
        }
    }
}

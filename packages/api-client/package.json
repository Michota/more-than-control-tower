{
    "name": "@mtct/api-client",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "exports": {
        ".": "./src/index.ts",
        "./hooks/*": "./src/gen/hooks/*.ts",
        "./clients/*": "./src/gen/clients/*.ts",
        "./models/*": "./src/gen/models/*.ts",
        "./zod/*": "./src/gen/zod/*.ts"
    },
    "scripts": {
        "export:openapi": "curl -sf http://localhost:3000/api-json | npx prettier --parser json > openapi.json",
        "generate": "kubb generate",
        "sync": "pnpm export:openapi && pnpm generate"
    },
    "dependencies": {
        "ky": "1.8.1"
    },
    "peerDependencies": {
        "@tanstack/react-query": ">=5",
        "zod": ">=3"
    },
    "devDependencies": {
        "@kubb/cli": "3.5.0",
        "@kubb/core": "3.5.0",
        "@kubb/plugin-client": "3.5.0",
        "@kubb/plugin-oas": "3.5.0",
        "@kubb/plugin-react-query": "3.5.0",
        "@kubb/plugin-ts": "3.5.0",
        "@kubb/plugin-zod": "3.5.0",
        "@mtct/typescript-config": "workspace:*"
    }
}

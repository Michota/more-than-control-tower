{
    "name": "@mtct/api-client",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "exports": {
        ".": "./src/index.ts",
        "./gen/hooks/*": "./src/gen/hooks/*.ts",
        "./gen/clients/*": "./src/gen/clients/*.ts",
        "./gen/models/*": "./src/gen/models/*.ts",
        "./gen/zod/*": "./src/gen/zod/*.ts"
    },

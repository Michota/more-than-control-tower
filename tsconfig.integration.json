{
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "target": "ES2023",
        "strict": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "declaration": false,
        "skipLibCheck": true,
        "baseUrl": "./"
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
